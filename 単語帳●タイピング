<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>単語帳タイピング</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/tesseract.js/4.1.1/tesseract.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Kaisei+Decol:wght@400;700&family=DM+Mono:wght@400;500&display=swap');

:root {
  --bg: #fdf6ec;
  --card: #fffdf8;
  --ink: #1a1208;
  --muted: #8a7a60;
  --border: #e0d4bc;
  --accent: #c84b2f;
  --accent2: #2f6bc8;
  --correct: #2a7a3b;
  --wrong: #c84b2f;
  --radius: 20px;
}

* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

body {
  background: var(--bg);
  color: var(--ink);
  font-family: 'Kaisei Decol', serif;
  min-height: 100dvh;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    repeating-linear-gradient(0deg, transparent, transparent 31px, rgba(180,160,120,0.07) 31px, rgba(180,160,120,0.07) 32px),
    repeating-linear-gradient(90deg, transparent, transparent 31px, rgba(180,160,120,0.04) 31px, rgba(180,160,120,0.04) 32px);
  pointer-events: none;
  z-index: 0;
}

.app {
  width: 100%;
  max-width: 480px;
  min-height: 100dvh;
  display: flex;
  flex-direction: column;
  padding: 0 16px 40px;
  position: relative;
  z-index: 1;
}

.header {
  padding: 20px 0 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--border);
  margin-bottom: 16px;
}

.logo { font-size: 1.05rem; font-weight: 700; letter-spacing: 0.05em; }
.logo .dot { color: var(--accent); }

.progress-badge {
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  color: var(--muted);
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 4px 12px;
}

/* OCR */
.ocr-section {
  background: var(--card);
  border: 1.5px dashed var(--border);
  border-radius: var(--radius);
  padding: 14px 16px;
  margin-bottom: 14px;
}

.ocr-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.ocr-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.5; }
.ocr-desc strong { display: block; font-size: 0.9rem; color: var(--ink); margin-bottom: 2px; }

.shoot-btn-wrap { position: relative; flex-shrink: 0; }

.shoot-btn {
  background: var(--accent);
  color: #fff;
  border: none;
  border-radius: 12px;
  padding: 12px 18px;
  font-family: 'Kaisei Decol', serif;
  font-weight: 700;
  font-size: 0.9rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: transform 0.15s;
  white-space: nowrap;
}

.shoot-btn:active { transform: scale(0.94); }

.ocr-file {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
  width: 100%;
  height: 100%;
}

.ocr-progress-wrap { margin-top: 10px; display: none; }
.ocr-progress-wrap.show { display: block; }

.ocr-bar-track { height: 3px; background: var(--border); border-radius: 999px; overflow: hidden; }
.ocr-bar { height: 100%; background: var(--accent); width: 0%; transition: width 0.3s; }
.ocr-msg { font-size: 0.7rem; color: var(--accent); font-family: 'DM Mono', monospace; margin-top: 4px; }

/* Word list */
.wordlist-section {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px 14px;
  margin-bottom: 14px;
  max-height: 100px;
  overflow-y: auto;
}

.wordlist-label {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--muted);
  margin-bottom: 8px;
}

.wordlist-items { display: flex; flex-wrap: wrap; gap: 6px; }

.word-chip {
  display: flex;
  align-items: center;
  gap: 5px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 4px 10px;
  font-size: 0.72rem;
  font-family: 'DM Mono', monospace;
  color: var(--muted);
  transition: all 0.2s;
}

.word-chip.active { border-color: var(--accent2); color: var(--accent2); background: rgba(47,107,200,0.06); }
.word-chip.done { opacity: 0.3; text-decoration: line-through; }
.word-chip .en { color: var(--ink); font-weight: 500; }
.word-chip .sep { color: var(--border); }

.empty-msg { font-size: 0.8rem; color: var(--muted); text-align: center; padding: 8px 0; line-height: 1.7; }

/* Quiz card */
.quiz-card {
  flex: 1;
  background: var(--card);
  border: 1.5px solid var(--border);
  border-radius: 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32px 24px 28px;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  min-height: 260px;
  transition: border-color 0.3s, box-shadow 0.3s;
}

.quiz-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 0; height: 0;
  border-style: solid;
  border-width: 36px 36px 0 0;
  border-color: var(--accent) transparent transparent transparent;
  border-radius: 28px 0 0 0;
}

.quiz-card.correct-flash {
  animation: cardFlash 0.5s ease forwards;
}

@keyframes cardFlash {
  0%   { border-color: var(--correct); box-shadow: 0 0 0 3px rgba(42,122,59,0.2); }
  100% { border-color: var(--border); box-shadow: none; }
}

.card-counter {
  position: absolute;
  top: 14px; right: 18px;
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  color: var(--muted);
}

.tap-to-start {
  position: absolute;
  bottom: 16px;
  font-size: 0.68rem;
  color: var(--muted);
  letter-spacing: 0.04em;
}

/* Japanese meaning */
.meaning-display {
  font-size: clamp(2rem, 11vw, 3.2rem);
  font-weight: 700;
  color: var(--ink);
  text-align: center;
  line-height: 1.2;
  margin-bottom: 24px;
  min-height: 68px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Chars */
.chars-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1px;
  margin-bottom: 8px;
  min-height: 52px;
  align-items: flex-end;
}

.ch {
  font-family: 'DM Mono', monospace;
  font-size: clamp(1.8rem, 8vw, 2.6rem);
  font-weight: 500;
  line-height: 1;
  transition: color 0.1s;
  position: relative;
}

.ch.pending { color: var(--border); }
.ch.correct-ch { color: var(--correct); }
.ch.wrong-ch { color: var(--wrong); animation: wobble 0.2s ease; }

.ch.cursor-ch::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
  background: var(--accent2);
  border-radius: 2px;
  animation: blink 0.9s step-end infinite;
}

@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
@keyframes wobble { 0%,100%{transform:translateX(0)} 30%{transform:translateX(-3px)} 70%{transform:translateX(3px)} }

.hint-line { font-size: 0.68rem; color: var(--muted); font-family: 'DM Mono', monospace; }

.hidden-input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
  width: 1px; height: 1px;
  top: 50%; left: 50%;
  font-size: 16px;
}

/* Progress */
.prog-wrap { margin-top: 14px; }
.prog-track { height: 5px; background: var(--border); border-radius: 999px; overflow: hidden; }
.prog-fill { height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent2)); border-radius: 999px; transition: width 0.5s cubic-bezier(0.34,1.56,0.64,1); }
.prog-labels { display: flex; justify-content: space-between; font-size: 0.65rem; color: var(--muted); margin-top: 5px; font-family: 'DM Mono', monospace; }

/* Complete */
.complete-wrap { display: none; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 18px; flex: 1; padding: 40px 0; }
.complete-wrap.show { display: flex; }

.complete-stamp {
  width: 90px; height: 90px;
  border: 4px solid var(--accent); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem; color: var(--accent);
  animation: stamp 0.5s cubic-bezier(0.34,1.56,0.64,1);
  font-weight: 700;
}

@keyframes stamp { 0%{transform:scale(2);opacity:0} 100%{transform:scale(1);opacity:1} }

.complete-title { font-size: 1.6rem; font-weight: 700; }
.complete-sub { font-size: 0.85rem; color: var(--muted); font-family: 'DM Mono', monospace; }

.again-btn {
  background: var(--ink); color: var(--bg);
  border: none; border-radius: 14px;
  padding: 14px 36px;
  font-family: 'Kaisei Decol', serif;
  font-weight: 700; font-size: 1rem;
  cursor: pointer; transition: transform 0.15s;
}

.again-btn:active { transform: scale(0.95); }

/* Particles */
.particle {
  position: fixed; pointer-events: none; z-index: 999;
  border-radius: 2px;
  animation: pfly 0.9s ease-out forwards;
}

@keyframes pfly {
  0% { transform: translate(0,0) rotate(0deg) scale(1); opacity: 1; }
  100% { transform: translate(var(--tx),var(--ty)) rotate(var(--tr)) scale(0); opacity: 0; }
}

/* Toast */
.toast {
  position: fixed; bottom: 28px; left: 50%;
  transform: translateX(-50%) translateY(80px);
  background: var(--ink); color: var(--bg);
  border-radius: 999px; padding: 10px 22px;
  font-size: 0.78rem; font-family: 'DM Mono', monospace;
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
  z-index: 1000; white-space: nowrap; max-width: 90vw;
  overflow: hidden; text-overflow: ellipsis;
}

.toast.show { transform: translateX(-50%) translateY(0); }
</style>
</head>
<body>
<div class="app">

  <div class="header">
    <div class="logo">単語帳<span class="dot">●</span>タイピング</div>
    <div class="progress-badge" id="badge">0 / 0</div>
  </div>

  <div class="ocr-section">
    <div class="ocr-top">
      <div class="ocr-desc">
        <strong>📷 単語帳を撮影</strong>
        英語｜日本語 の2列を読み取ります
      </div>
      <div class="shoot-btn-wrap">
        <button class="shoot-btn">📷 撮影</button>
        <input class="ocr-file" type="file" accept="image/*" capture="environment" id="ocrFile">
      </div>
    </div>
    <div class="ocr-progress-wrap" id="ocrWrap">
      <div class="ocr-bar-track"><div class="ocr-bar" id="ocrBar"></div></div>
      <div class="ocr-msg" id="ocrMsg">読み取り中...</div>
    </div>
  </div>

  <div class="wordlist-section">
    <div class="wordlist-label">読み込んだ単語</div>
    <div class="wordlist-items" id="wordList">
      <div class="empty-msg">📷 単語帳を撮影してください</div>
    </div>
  </div>

  <div class="quiz-card" id="quizCard">
    <div class="card-counter" id="counter"></div>
    <div class="meaning-display" id="meaningDisplay">
      <span style="font-size:1rem;color:var(--muted);font-weight:400">単語帳を撮影して<br>練習を始めましょう</span>
    </div>
    <div class="chars-row" id="charsRow"></div>
    <div class="hint-line" id="hintLine"></div>
    <div class="tap-to-start" id="tapHint">タップしてキーボード表示</div>
    <input class="hidden-input" type="text" id="hiddenInput"
      autocomplete="off" autocorrect="off" autocapitalize="off"
      spellcheck="false" inputmode="text">
  </div>

  <div class="complete-wrap" id="completeWrap">
    <div class="complete-stamp">合格</div>
    <div class="complete-title">全問正解！</div>
    <div class="complete-sub" id="completeSub"></div>
    <button class="again-btn" id="againBtn">もう一度</button>
  </div>

  <div class="prog-wrap">
    <div class="prog-track"><div class="prog-fill" id="progFill" style="width:0%"></div></div>
    <div class="prog-labels">
      <span id="progLeft">0 完了</span>
      <span id="progRight">0%</span>
    </div>
  </div>

</div>

<div class="toast" id="toast"></div>

<script>
let words = [];   // [{ en, ja }]
let idx = 0, charIdx = 0;
let wrongSet = new Set();
let isActive = false, startTime = null;

const quizCard       = document.getElementById('quizCard');
const hiddenInput    = document.getElementById('hiddenInput');
const meaningDisplay = document.getElementById('meaningDisplay');
const charsRow       = document.getElementById('charsRow');
const hintLine       = document.getElementById('hintLine');
const counter        = document.getElementById('counter');
const tapHint        = document.getElementById('tapHint');
const badge          = document.getElementById('badge');
const progFill       = document.getElementById('progFill');
const progLeft       = document.getElementById('progLeft');
const progRight      = document.getElementById('progRight');
const completeWrap   = document.getElementById('completeWrap');
const completeSub    = document.getElementById('completeSub');
const againBtn       = document.getElementById('againBtn');

// ── Audio ──────────────────────────────────────────────────────────────────
let actx = null;
function getActx() { return actx || (actx = new (window.AudioContext||window.webkitAudioContext)()); }

function playBeep() {
  try {
    const ctx = getActx();
    [660, 880, 1320].forEach((freq, i) => {
      const o = ctx.createOscillator(), g = ctx.createGain();
      o.connect(g); g.connect(ctx.destination);
      o.frequency.value = freq;
      const t = ctx.currentTime + i * 0.08;
      g.gain.setValueAtTime(0.22, t);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.15);
      o.start(t); o.stop(t + 0.15);
    });
  } catch(e) {}
}

function speak(word) {
  if (!window.speechSynthesis) return;
  speechSynthesis.cancel();
  setTimeout(() => {
    const u = new SpeechSynthesisUtterance(word);
    u.lang = 'en-US'; u.rate = 0.85;
    speechSynthesis.speak(u);
  }, 200);
}

// ── Render ─────────────────────────────────────────────────────────────────
function renderList() {
  const el = document.getElementById('wordList');
  if (!words.length) {
    el.innerHTML = '<div class="empty-msg">📷 単語帳を撮影してください</div>';
    return;
  }
  el.innerHTML = words.map((w, i) => {
    let c = 'word-chip';
    if (i === idx && isActive) c += ' active';
    if (i < idx) c += ' done';
    return `<span class="${c}"><span class="en">${w.en}</span><span class="sep"> | </span><span class="ja">${w.ja}</span></span>`;
  }).join('');
}

function renderQuiz() {
  if (!words.length) {
    meaningDisplay.innerHTML = '<span style="font-size:1rem;color:var(--muted);font-weight:400">単語帳を撮影して<br>練習を始めましょう</span>';
    charsRow.innerHTML = ''; hintLine.textContent = ''; counter.textContent = '';
    tapHint.style.display = '';
    return;
  }
  if (idx >= words.length) { showComplete(); return; }
  const w = words[idx];
  meaningDisplay.textContent = w.ja;
  counter.textContent = `${idx + 1} / ${words.length}`;
  tapHint.style.display = 'none';
  charsRow.innerHTML = w.en.split('').map((ch, i) => {
    const c = 'ch pending' + (i === charIdx ? ' cursor-ch' : '');
    return `<span class="${c}">${ch === ' ' ? '&nbsp;' : ch}</span>`;
  }).join('');
  hintLine.textContent = '▲ タップして入力開始';
}

function updateChars() {
  charsRow.querySelectorAll('.ch').forEach((s, i) => {
    s.className = 'ch';
    if (i < charIdx) s.classList.add(wrongSet.has(i) ? 'wrong-ch' : 'correct-ch');
    else if (i === charIdx) s.classList.add('pending', 'cursor-ch');
    else s.classList.add('pending');
  });
}

// ── Input ──────────────────────────────────────────────────────────────────
quizCard.addEventListener('click', () => {
  if (!words.length) return;
  isActive = true;
  hiddenInput.focus();
  if (!startTime) startTime = Date.now();
  renderQuiz();
});

hiddenInput.addEventListener('blur', () => {
  if (isActive) hintLine.textContent = '▲ タップして再開';
});

hiddenInput.addEventListener('input', () => {
  if (idx >= words.length) return;
  const val = hiddenInput.value;
  if (!val.length) return;
  const ch = val[val.length - 1].toLowerCase();
  hiddenInput.value = '';

  const word = words[idx].en.toLowerCase();
  if (charIdx >= word.length) return;

  if (ch === word[charIdx]) {
    charIdx++;
    updateChars();
    if (charIdx === word.length) {
      playBeep();
      speak(words[idx].en);
      burst();
      quizCard.classList.remove('correct-flash');
      void quizCard.offsetWidth;
      quizCard.classList.add('correct-flash');
      setTimeout(() => {
        idx++; charIdx = 0; wrongSet.clear();
        if (idx >= words.length) showComplete();
        else { renderQuiz(); hiddenInput.focus(); }
        renderList(); updateProgress();
      }, 520);
    }
  } else {
    wrongSet.add(charIdx);
    updateChars();
    setTimeout(() => { wrongSet.delete(charIdx); updateChars(); }, 300);
  }
});

hiddenInput.addEventListener('keydown', (e) => {
  if (e.key === 'Backspace' && charIdx > 0) {
    charIdx--; wrongSet.delete(charIdx); updateChars(); e.preventDefault();
  }
});

// ── Progress ───────────────────────────────────────────────────────────────
function updateProgress() {
  const total = words.length, done = idx;
  const pct = total ? Math.round(done / total * 100) : 0;
  progFill.style.width = pct + '%';
  progLeft.textContent = `${done} 完了`;
  progRight.textContent = pct + '%';
  badge.textContent = `${done} / ${total}`;
}

// ── Complete ───────────────────────────────────────────────────────────────
function showComplete() {
  isActive = false;
  quizCard.style.display = 'none';
  completeWrap.classList.add('show');
  const sec = startTime ? Math.round((Date.now() - startTime) / 1000) : 0;
  completeSub.textContent = `${words.length}語 完了 · ${sec}秒`;
  updateProgress();
}

againBtn.addEventListener('click', () => {
  idx = 0; charIdx = 0; wrongSet.clear();
  startTime = Date.now(); isActive = true;
  completeWrap.classList.remove('show');
  quizCard.style.display = '';
  renderQuiz(); renderList(); updateProgress();
  hiddenInput.focus();
});

// ── Particles ──────────────────────────────────────────────────────────────
function burst() {
  const colors = ['#c84b2f','#2f6bc8','#2a7a3b','#c8a22f','#8a2fc8'];
  const r = quizCard.getBoundingClientRect();
  const cx = r.left + r.width / 2, cy = r.top + r.height / 2;
  for (let i = 0; i < 16; i++) {
    const el = document.createElement('div');
    el.className = 'particle';
    const sz = 5 + Math.random() * 8;
    const ang = Math.PI * 2 * i / 16 + (Math.random()-.5)*.5;
    const dist = 60 + Math.random() * 80;
    el.style.cssText = `width:${sz}px;height:${sz}px;background:${colors[i%colors.length]};left:${cx}px;top:${cy}px;--tx:${Math.cos(ang)*dist}px;--ty:${Math.sin(ang)*dist}px;--tr:${(Math.random()-.5)*200}deg;`;
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 900);
  }
}

// ── Toast ──────────────────────────────────────────────────────────────────
function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg; el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 2600);
}

// ── OCR ────────────────────────────────────────────────────────────────────
document.getElementById('ocrFile').addEventListener('change', async (e) => {
  const file = e.target.files[0];
  if (!file) return;
  e.target.value = '';

  const wrap = document.getElementById('ocrWrap');
  const bar  = document.getElementById('ocrBar');
  const msg  = document.getElementById('ocrMsg');

  wrap.classList.add('show');
  bar.style.width = '0%';
  msg.textContent = '読み取り中...';

  try {
    const worker = await Tesseract.createWorker('eng+jpn', 1, {
      logger: m => {
        if (m.status === 'recognizing text') {
          bar.style.width = Math.round(m.progress * 100) + '%';
          msg.textContent = `認識中... ${Math.round(m.progress * 100)}%`;
        }
      }
    });

    const { data: { text } } = await worker.recognize(file);
    await worker.terminate();

    // Parse English | Japanese pairs
    const pairs = [];
    const lines = text.split('\n').map(l => l.trim()).filter(l => l.length > 1);

    for (const line of lines) {
      // Split by | ｜ tab :: multiple spaces
      const parts = line.split(/[|｜\t:：]\s*|\s{2,}/);
      if (parts.length >= 2) {
        const left  = parts[0].trim();
        const right = parts.slice(1).join(' ').trim();
        const leftIsEn  = /^[a-zA-Z]/.test(left) && /^[a-zA-Z\s'\-.,!?]+$/.test(left);
        const rightIsEn = /^[a-zA-Z]/.test(right) && /^[a-zA-Z\s'\-.,!?]+$/.test(right);
        let en = '', ja = '';
        if (leftIsEn && !rightIsEn) { en = left; ja = right; }
        else if (rightIsEn && !leftIsEn) { en = right; ja = left; }
        en = en.toLowerCase().replace(/[^a-z\s]/g,'').trim();
        if (en.length >= 2 && ja.length >= 1) pairs.push({ en, ja });
      }
    }

    bar.style.width = '100%';

    if (!pairs.length) {
      msg.textContent = '⚠ ペアが見つかりませんでした。明るい場所で撮り直してみてください';
      setTimeout(() => wrap.classList.remove('show'), 3500);
      return;
    }

    const existing = new Set(words.map(w => w.en));
    const newPairs = pairs.filter(p => !existing.has(p.en));
    words.push(...newPairs);

    msg.textContent = `✓ ${newPairs.length}語を追加しました！`;
    setTimeout(() => wrap.classList.remove('show'), 2000);
    showToast(`📚 ${newPairs.length}語を追加しました`);

    if (!isActive && idx < words.length) {
      idx = 0; charIdx = 0; wrongSet.clear();
      startTime = Date.now(); isActive = true;
      quizCard.style.display = '';
      completeWrap.classList.remove('show');
      renderQuiz(); updateProgress();
    }
    renderList(); updateProgress();

  } catch(err) {
    msg.textContent = 'エラー: ' + err.message;
    setTimeout(() => wrap.classList.remove('show'), 3000);
  }
});

// ── Init ───────────────────────────────────────────────────────────────────
renderQuiz(); renderList(); updateProgress();
</script>
</body>
</html>
